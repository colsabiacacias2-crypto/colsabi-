generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  ASOCIADO
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ScenarioStatus {
  PENDING
  ACTIVE
  REJECTED
  INACTIVE
}

enum AssignmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum HourEntryStatus {
  PENDING
  APPROVED
  REJECTED
}

model Usuario {
  id                     String                @id @default(cuid())
  email                  String                @unique
  fullName               String
  passwordHash           String?
  role                   Role
  status                 UserStatus            @default(PENDING)
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  managedScenarios       EscenarioPractica[]    @relation("ScenarioManager")
  decidedApplications    PostulacionEscenario[] @relation("ApplicationDecision")
  hourReviews            RegistroHoraSocial[]     @relation("EntryReviewer")
  auditLogs              BitacoraAuditoria[]

  @@map("usuarios")
}

model PostulacionEscenario {
  id                     String            @id @default(cuid())
  organizationName       String
  contactName            String
  contactEmail           String
  contactPhone           String
  city                   String
  address                String?
  capacity               Int?
  description            String
  status                 ApplicationStatus @default(PENDING)
  notes                  String?
  submittedAt            DateTime          @default(now())
  reviewedAt             DateTime?
  approvedScenarioId     String?           @unique
  decidedByUserId        String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  approvedScenario       EscenarioPractica? @relation(fields: [approvedScenarioId], references: [id])
  decidedBy              Usuario?             @relation("ApplicationDecision", fields: [decidedByUserId], references: [id])

  @@map("postulaciones_escenarios")
}

model EscenarioPractica {
  id                     String                     @id @default(cuid())
  name                   String
  slug                   String                     @unique
  description            String
  city                   String
  address                String?
  capacity               Int?
  status                 ScenarioStatus             @default(PENDING)
  managerUserId          String?
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  manager                Usuario?                      @relation("ScenarioManager", fields: [managerUserId], references: [id])
  application            PostulacionEscenario?
  studentAssignments     AsignacionEstudianteEscenario[]
  hourEntries            RegistroHoraSocial[]

  @@map("escenarios_practica")
}

model Estudiante {
  id                     String                     @id @default(cuid())
  studentCode            String                     @unique
  documentNumber         String?                    @unique
  fullName               String
  grade                  String
  section                String?
  email                  String?
  phone                  String?
  isActive               Boolean                    @default(true)
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  assignments            AsignacionEstudianteEscenario[]
  hourEntries            RegistroHoraSocial[]

  @@map("estudiantes")
}

model AsignacionEstudianteEscenario {
  id                     String           @id @default(cuid())
  studentId              String
  scenarioId             String
  assignedAt             DateTime         @default(now())
  completedAt            DateTime?
  requiredHours          Int              @default(80)
  approvedHours          Int              @default(0)
  status                 AssignmentStatus @default(ACTIVE)
  student                Estudiante          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  scenario               EscenarioPractica @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@unique([studentId, scenarioId])
  @@index([scenarioId, status])
  @@map("asignaciones_estudiantes_escenarios")
}

model RegistroHoraSocial {
  id                     String           @id @default(cuid())
  studentId              String
  scenarioId             String
  reviewedByUserId       String?
  workDate               DateTime
  hours                  Decimal          @db.Decimal(5, 2)
  activityTitle          String
  description            String
  evidenceUrl            String?
  evidenceName           String?
  evidenceMimeType       String?
  status                 HourEntryStatus  @default(PENDING)
  reviewNotes            String?
  reviewedAt             DateTime?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  student                Estudiante          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  scenario               EscenarioPractica @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  reviewedBy             Usuario?            @relation("EntryReviewer", fields: [reviewedByUserId], references: [id])

  @@index([studentId, status])
  @@index([scenarioId, status])
  @@index([workDate])
  @@map("registros_horas_sociales")
}

model BitacoraAuditoria {
  id                     String   @id @default(cuid())
  userId                 String?
  action                 String
  entity                 String
  entityId               String
  ipAddress              String?
  userAgent              String?
  details                Json?
  createdAt              DateTime @default(now())
  user                   Usuario?    @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([createdAt])
  @@map("bitacoras_auditoria")
}
